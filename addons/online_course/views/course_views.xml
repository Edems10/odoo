<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Kanban View -->
    <record id="view_online_course_kanban" model="ir.ui.view">
        <field name="name">online.course.kanban</field>
        <field name="model">online.course</field>
        <field name="arch" type="xml">
            <kanban default_order="name asc">
                <field name="state"/>
                <field name="teacher_id"/>
                <templates>
                    <t t-name="kanban-box">
                        <div t-attf-class="oe_kanban_global_click
                                           #{record.state.raw_value == 'published' ? 'oe_kanban_color_2' : ''}
                                           #{record.state.raw_value == 'draft' ? 'oe_kanban_color_4' : ''}">
                            <div class="o_kanban_record_top">
                                <div class="o_kanban_record_headings">
                                    <strong class="o_kanban_record_title">
                                        <field name="name"/>
                                    </strong>
                                </div>
                            </div>
                            <div class="o_kanban_record_body">
                                <div>Teacher: <field name="teacher_id"/></div>
                                <div>Price: <field name="price" widget="monetary"/></div>
                            </div>
                            <div class="o_kanban_record_bottom">
                                <div class="oe_kanban_bottom_left">
                                    <field name="state" widget="label_selection" options="{'classes': {'draft': 'default', 'published': 'success', 'archived': 'warning'}}"/>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_online_course_form" model="ir.ui.view">
        <field name="name">online.course.form</field>
        <field name="model">online.course</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_publish" string="Publish" type="object" class="btn-primary" invisible="state != 'draft'"/>
                    <button name="action_archive" string="Archive" type="object" invisible="state != 'published'"/>
                    <button name="action_draft" string="Set to Draft" type="object" invisible="state == 'draft'"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,published"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="e.g. Introduction to Odoo Development"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="teacher_id"/>
                            <field name="price" widget="monetary"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Description">
                            <field name="description"/>
                        </page>
                        <page string="Students">
                            <field name="student_ids"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- List View  -->
    <record id="view_online_course_list" model="ir.ui.view">
        <field name="name">online.course.list</field>
        <field name="model">online.course</field>
        <field name="arch" type="xml">
            <list> 
                <field name="name"/>
                <field name="teacher_id"/>
                <field name="price"/>
                <field name="state"/>
            </list>
        </field>
    </record>
</odoo>
