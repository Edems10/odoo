<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Window Action -->
    <record id="action_online_course" model="ir.actions.act_window">
        <field name="name">Courses</field>
        <field name="res_model">online.course</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create a new course
            </p>
        </field>
    </record>

    <!-- Menu Items -->
    <menuitem id="menu_online_course_root" name="Online Courses" sequence="10"/>
    <menuitem id="menu_online_course" name="Courses" parent="menu_online_course_root" action="action_online_course" sequence="10"/>
</odoo>
